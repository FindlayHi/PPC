---
layout: layouts/base.njk
title: "Contact | Port Credit Cleaning"
description: "Get in touch with Port Credit Cleaning. Call, text, or email — we reply the same day."
mobileCta: "message"
---

{# ── HEADER ── #}
<section class="bg-navy py-16 md:py-20">
  <div class="max-w-[840px] mx-auto px-8 text-center">
    <p class="text-sand text-[12.5px] font-semibold uppercase tracking-[0.13em] mb-4">Contact</p>
    <h1 class="font-display font-extrabold text-white text-[42px] md:text-[48px] leading-[1.07] tracking-[-0.022em] mb-5">Get in touch</h1>
    <p class="text-[#A8BDD0] text-[18px] leading-relaxed mb-8">Have a question or ready to book? Call, text, or send a message and we'll reply the same day.</p>
    <a href="{{ site.phoneTel }}" class="inline-flex items-center gap-2.5 bg-teal hover:bg-teal-hover text-white font-semibold text-[17px] px-8 py-4 rounded-[12px] transition-colors duration-150">
      <svg width="18" height="18" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/></svg>
      {{ site.phone }}
    </a>
  </div>
</section>

{# ── CONTACT BODY ── #}
<section class="py-20 bg-white">
  <div class="max-w-[1180px] mx-auto px-8 grid grid-cols-1 md:grid-cols-2 gap-14">

    {# Left: contact cards + map #}
    <div>
      <h2 class="font-display font-bold text-navy text-[24px] mb-7">Reach us directly</h2>
      <div class="space-y-4 mb-8">

        <div class="flex items-center gap-4 bg-surface rounded-[16px] p-5">
          <div class="w-11 h-11 bg-teal-tint rounded-[12px] flex items-center justify-center shrink-0">
            <svg width="18" height="18" viewBox="0 0 22 22" fill="none" stroke="#5AA7A7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/></svg>
          </div>
          <div>
            <p class="text-[12px] font-semibold uppercase tracking-[0.1em] text-[#6B7280] mb-0.5">Call or text</p>
            <a href="{{ site.phoneTel }}" class="text-navy font-semibold text-[16px] hover:text-teal transition-colors duration-150">{{ site.phone }}</a>
          </div>
        </div>

        <div class="flex items-center gap-4 bg-surface rounded-[16px] p-5">
          <div class="w-11 h-11 bg-teal-tint rounded-[12px] flex items-center justify-center shrink-0">
            <svg width="18" height="18" viewBox="0 0 22 22" fill="none" stroke="#5AA7A7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <p class="text-[12px] font-semibold uppercase tracking-[0.1em] text-[#6B7280] mb-0.5">Email</p>
            <a href="mailto:{{ site.email }}" class="text-navy font-semibold text-[16px] hover:text-teal transition-colors duration-150">{{ site.email }}</a>
          </div>
        </div>

        <div class="flex items-center gap-4 bg-surface rounded-[16px] p-5">
          <div class="w-11 h-11 bg-teal-tint rounded-[12px] flex items-center justify-center shrink-0">
            <svg width="18" height="18" viewBox="0 0 22 22" fill="none" stroke="#5AA7A7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p class="text-[12px] font-semibold uppercase tracking-[0.1em] text-[#6B7280] mb-0.5">Service area</p>
            <p class="text-navy font-semibold text-[16px]">Port Credit &amp; South Mississauga</p>
          </div>
        </div>
      </div>

      <div class="rounded-[16px] overflow-hidden w-full aspect-video">
        <iframe
          src="https://maps.google.com/maps?q=Port+Credit,+Mississauga+ON&output=embed&z=13"
          width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Port Credit, Mississauga ON map"></iframe>
      </div>
    </div>

    {# Right: contact form #}
    <div>
      <h3 class="font-display font-bold text-navy text-[22px] mb-2">Send a message</h3>
      <p class="text-[#4A5568] text-[15px] mb-6">We typically reply within a few hours.</p>
      {% include "partials/contact-form.njk" %}
    </div>
  </div>
</section>
