---
pagination:
  data: services
  size: 1
  alias: service
permalink: "/services/{{ service.slug }}/"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ service.h1 }} | Port Credit Cleaners"
  description: "{{ service.subhead }}"
---

{# ── BREADCRUMB + HERO ── #}
<section class="bg-navy py-14 md:py-20">
  <div class="max-w-[1180px] mx-auto px-8">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-2 text-[13px] text-[#5A7290]">
        <li><a href="/services/" class="hover:text-white transition-colors duration-150">Services</a></li>
        <li aria-hidden="true"><span class="mx-1">&rsaquo;</span></li>
        <li class="text-[#A8BDD0]">{{ service.cardTitle }}</li>
      </ol>
    </nav>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-sand text-[12.5px] font-semibold uppercase tracking-[0.13em] mb-4">{{ service.eyebrow }}</p>
        <h1 class="font-display font-extrabold text-white text-[40px] md:text-[48px] leading-[1.07] tracking-[-0.022em] mb-5">{{ service.h1 }}</h1>
        <p class="text-[#A8BDD0] text-[17px] leading-relaxed mb-8">{{ service.subhead }}</p>
        <div class="flex flex-wrap gap-3">
          <a href="#quote" class="bg-teal hover:bg-teal-hover text-white font-semibold text-[15px] px-6 py-3 rounded-[10px] transition-colors duration-150">Get a Free Quote</a>
          <a href="{{ site.phoneSms }}" class="bg-white/10 hover:bg-white/20 text-white font-semibold text-[15px] px-6 py-3 rounded-[10px] transition-colors duration-150">Text Us</a>
        </div>
      </div>
      <div class="hidden md:block">
        <div class="rounded-[20px] overflow-hidden w-full aspect-[4/3]">
          {% image "/img/" + service.imageFile, service.imageAlt, "w-full h-full object-cover", "(min-width: 768px) 50vw, 100vw" %}
        </div>
      </div>
    </div>
  </div>
</section>

{# ── INTRO + AT A GLANCE ── #}
<section class="py-20 bg-white">
  <div class="max-w-[1180px] mx-auto px-8 grid grid-cols-1 md:grid-cols-2 gap-14 items-start">
    <div>
      <h2 class="font-display font-extrabold text-navy text-[32px] leading-[1.1] tracking-[-0.022em] mb-6">{{ service.introH2 }}</h2>
      <div class="space-y-4 text-[16.5px] text-[#4A5568] leading-[1.7]">
        {% for p in service.intro %}
        <p>{{ p }}</p>
        {% endfor %}
      </div>
    </div>
    <div class="bg-surface rounded-[20px] p-7" style="box-shadow: 0 10px 30px rgba(23,50,77,.05);">
      <h3 class="font-display font-bold text-navy text-[16px] uppercase tracking-[0.05em] mb-5">At a glance</h3>
      <ul class="space-y-3.5">
        {% for item in service.ataglance %}
        <li class="flex items-start gap-2.5">
          <span class="shrink-0 w-4 h-4 rounded-full bg-teal flex items-center justify-center mt-0.5">
            <svg width="8" height="6" viewBox="0 0 8 6" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 3 3 5 7 1"/></svg>
          </span>
          <span class="text-[15px] text-ink">{{ item }}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

{# ── WHAT'S INCLUDED ── #}
<section class="py-20 bg-surface">
  <div class="max-w-[1180px] mx-auto px-8">
    <p class="text-teal text-[12.5px] font-semibold uppercase tracking-[0.13em] mb-3">What's included</p>
    <h2 class="font-display font-extrabold text-navy text-[32px] leading-[1.1] tracking-[-0.022em] mb-10">{{ service.includesH2 }}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-5 mb-7">
      {% for item in service.includes %}
      <div class="flex items-start gap-3">
        <span class="shrink-0 w-5 h-5 rounded-full bg-teal flex items-center justify-center mt-0.5">
          <svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 3.5 6.5 9 1"/></svg>
        </span>
        <p class="text-[15.5px] text-ink leading-relaxed"><strong class="font-semibold">{{ item.heading }}</strong> — {{ item.detail }}</p>
      </div>
      {% endfor %}
    </div>
    {% if service.includesNote %}
    <p class="text-[14px] text-[#6B7280] bg-white rounded-[12px] p-4 border border-[#E2E6EC]">{{ service.includesNote }}</p>
    {% endif %}
  </div>
</section>

{# ── WHO IT'S FOR ── #}
<section class="py-20 bg-white">
  <div class="max-w-[1180px] mx-auto px-8">
    <p class="text-teal text-[12.5px] font-semibold uppercase tracking-[0.13em] mb-3">Who it's for</p>
    <h2 class="font-display font-extrabold text-navy text-[32px] leading-[1.1] tracking-[-0.022em] mb-10">{{ service.whoForH2 }}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-7">
      {% for w in service.whoFor %}
      <div class="bg-surface rounded-[16px] p-6" style="box-shadow: 0 10px 30px rgba(23,50,77,.05);">
        <h3 class="font-display font-bold text-navy text-[18px] mb-2">{{ w.title }}</h3>
        <p class="text-[#4A5568] text-[15px] leading-relaxed">{{ w.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ── WHY LOCAL ── #}
<section class="py-20 bg-navy">
  <div class="max-w-[1180px] mx-auto px-8 grid grid-cols-1 md:grid-cols-2 gap-14 items-center">
    <div>
      <p class="text-sand text-[12.5px] font-semibold uppercase tracking-[0.13em] mb-3">Local &amp; trusted</p>
      <h2 class="font-display font-extrabold text-white text-[32px] leading-[1.1] tracking-[-0.022em] mb-6">{{ service.whyLocalH2 }}</h2>
      <div class="space-y-4 text-[#A8BDD0] text-[16px] leading-[1.7] mb-8">
        {% for p in service.whyLocal %}
        <p>{{ p }}</p>
        {% endfor %}
      </div>
      <div class="flex flex-wrap gap-2">
        {% for n in site.neighborhoods %}
        <span class="bg-white/10 text-[#CDD6E0] font-semibold text-[13px] px-3.5 py-1.5 rounded-full">{{ n }}</span>
        {% endfor %}
      </div>
    </div>
    <div class="rounded-[20px] overflow-hidden w-full aspect-[4/3]">
      <iframe
        src="https://maps.google.com/maps?q=Port+Credit,+Mississauga+ON&output=embed&z=13"
        width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Port Credit, Mississauga ON map"></iframe>
    </div>
  </div>
</section>

{# ── FAQ ── #}
<section class="py-20 bg-surface">
  <div class="max-w-[840px] mx-auto px-8">
    <p class="text-teal text-[12.5px] font-semibold uppercase tracking-[0.13em] mb-3">FAQ</p>
    <h2 class="font-display font-extrabold text-navy text-[32px] leading-[1.1] tracking-[-0.022em] mb-10">{{ service.faqH2 }}</h2>
    <div class="space-y-5">
      {% for faq in service.faq %}
      <div class="bg-white rounded-[16px] p-7" style="box-shadow: 0 10px 30px rgba(23,50,77,.05);">
        <h3 class="font-display font-bold text-navy text-[17px] mb-3">{{ faq.q }}</h3>
        <p class="text-[#4A5568] text-[15.5px] leading-relaxed">{{ faq.a }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ── QUOTE BAND ── #}
<section id="quote" class="py-16 bg-navy">
  <div class="max-w-[1180px] mx-auto px-8 grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
    <div>
      <p class="text-sand text-[12.5px] font-semibold uppercase tracking-[0.13em] mb-3">Free quote</p>
      <h2 class="font-display font-extrabold text-white text-[32px] leading-[1.1] tracking-[-0.022em] mb-4">{{ service.quoteBandH2 }}</h2>
      <p class="text-[#A8BDD0] text-[17px] leading-relaxed mb-6">Tell us about your home and we'll reply the same day with honest, upfront pricing — no obligation.</p>
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-white/10 rounded-[10px] flex items-center justify-center shrink-0">
          <svg width="16" height="16" viewBox="0 0 22 22" fill="none" stroke="#5AA7A7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/></svg>
        </div>
        <div>
          <p class="text-[12px] font-semibold uppercase tracking-[0.1em] text-[#5A7290]">Call or text</p>
          <a href="{{ site.phoneTel }}" class="text-white font-semibold text-[15px] hover:text-teal transition-colors duration-150">{{ site.phone }}</a>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-[16px] p-7">
      {% set formType = "compact" %}
      {% include "partials/quote-form.njk" %}
    </div>
  </div>
</section>
