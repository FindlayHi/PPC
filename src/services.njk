---
layout: layouts/base.njk
title: "Cleaning Services in Port Credit | Port Credit Cleaners"
description: "House & condo cleaning services in Port Credit — recurring, deep, move-in/out, condo and Airbnb turnovers. Book online or call (905) 555-0199."
---

{# ── HERO ── #}
<section class="bg-navy py-16 md:py-20">
  <div class="max-w-[840px] mx-auto px-8 text-center">
    <p class="text-sand text-[12.5px] font-semibold uppercase tracking-[0.13em] mb-4">Our services</p>
    <h1 class="font-display font-extrabold text-white text-[42px] md:text-[48px] leading-[1.07] tracking-[-0.022em] mb-5">House &amp; condo cleaning, done properly in Port Credit</h1>
    <p class="text-[#A8BDD0] text-[18px] leading-relaxed mb-8">From weekly upkeep to detailed deep cleans and move-out resets — reliable cleaning tailored to your home and your schedule.</p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/#quote" class="bg-teal hover:bg-teal-hover text-white font-semibold text-[15px] px-6 py-3 rounded-[10px] transition-colors duration-150">Get a Free Quote</a>
      <a href="{{ site.phoneSms }}" class="bg-white/10 hover:bg-white/20 text-white font-semibold text-[15px] px-6 py-3 rounded-[10px] transition-colors duration-150">Text Us</a>
    </div>
  </div>
  <div class="max-w-[1180px] mx-auto px-8 pb-16 hidden md:block">
    <div class="rounded-[20px] overflow-hidden w-full" style="height:320px;">
      {% image "/img/roam-in-color-z3QZ6gjGRt4-unsplash.jpg", "Premium clean kitchen with white hex tiles and marble counters", "w-full h-full object-cover object-center", "100vw" %}
    </div>
  </div>
</section>

{# ── SERVICE BLOCKS ── #}
{% for s in services %}
<section class="py-16 md:py-20 {% if loop.index % 2 == 0 %}bg-surface{% else %}bg-white{% endif %}">
  <div class="max-w-[1180px] mx-auto px-8 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    {% if loop.index % 2 == 0 %}
    {# Image right on even #}
    <div>
      <p class="text-teal text-[12px] font-semibold uppercase tracking-[0.13em] mb-3">{{ s.servicesPageEyebrow }}</p>
      <h2 class="font-display font-extrabold text-navy text-[30px] leading-[1.15] tracking-[-0.022em] mb-4">{{ s.cardTitle }}</h2>
      <p class="text-[#4A5568] text-[16.5px] leading-relaxed mb-6">{{ s.servicesPageDesc }}</p>
      <div class="flex flex-wrap gap-2 mb-6">
        {% for chip in s.servicesPageChips %}
        <span class="bg-teal-tint text-teal font-semibold text-[13px] px-3.5 py-1.5 rounded-full">{{ chip }}</span>
        {% endfor %}
      </div>
      <a href="/services/{{ s.slug }}/" class="text-teal font-semibold text-[15px] hover:underline">Read full details &rarr;</a>
    </div>
    <div class="rounded-[20px] overflow-hidden w-full aspect-[4/3]">
      {% image "/img/" + s.imageFile, s.imageAlt, "w-full h-full object-cover", "(min-width: 768px) 50vw, 100vw" %}
    </div>
    {% else %}
    {# Image left on odd #}
    <div class="rounded-[20px] overflow-hidden w-full aspect-[4/3] order-2 md:order-1">
      {% image "/img/" + s.imageFile, s.imageAlt, "w-full h-full object-cover", "(min-width: 768px) 50vw, 100vw" %}
    </div>
    <div class="order-1 md:order-2">
      <p class="text-teal text-[12px] font-semibold uppercase tracking-[0.13em] mb-3">{{ s.servicesPageEyebrow }}</p>
      <h2 class="font-display font-extrabold text-navy text-[30px] leading-[1.15] tracking-[-0.022em] mb-4">{{ s.cardTitle }}</h2>
      <p class="text-[#4A5568] text-[16.5px] leading-relaxed mb-6">{{ s.servicesPageDesc }}</p>
      <div class="flex flex-wrap gap-2 mb-6">
        {% for chip in s.servicesPageChips %}
        <span class="bg-teal-tint text-teal font-semibold text-[13px] px-3.5 py-1.5 rounded-full">{{ chip }}</span>
        {% endfor %}
      </div>
      <a href="/services/{{ s.slug }}/" class="text-teal font-semibold text-[15px] hover:underline">Read full details &rarr;</a>
    </div>
    {% endif %}
  </div>
</section>
{% endfor %}

{# ── COMPACT QUOTE BAND ── #}
<section class="py-16 bg-navy">
  <div class="max-w-[1180px] mx-auto px-8 grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
    <div>
      <p class="text-sand text-[12.5px] font-semibold uppercase tracking-[0.13em] mb-3">Free quote</p>
      <h2 class="font-display font-extrabold text-white text-[32px] leading-[1.1] tracking-[-0.022em] mb-4">Tell us about your home</h2>
      <p class="text-[#A8BDD0] text-[17px] leading-relaxed mb-6">Send a few details and we'll reply the same day with honest, upfront pricing — no obligation.</p>
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-white/10 rounded-[10px] flex items-center justify-center shrink-0">
          <svg width="16" height="16" viewBox="0 0 22 22" fill="none" stroke="#5AA7A7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/></svg>
        </div>
        <div>
          <p class="text-[12px] font-semibold uppercase tracking-[0.1em] text-[#5A7290]">Call or text</p>
          <a href="{{ site.phoneTel }}" class="text-white font-semibold text-[15px] hover:text-teal transition-colors duration-150">{{ site.phone }}</a>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-[16px] p-7">
      {% set formType = "compact" %}
      {% include "partials/quote-form.njk" %}
    </div>
  </div>
</section>
