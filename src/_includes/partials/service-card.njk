<a href="/services/{{ card.slug }}/" class="group block bg-white rounded-[16px] p-6 transition-all duration-[220ms] ease-out hover:-translate-y-1 no-underline" style="box-shadow: 0 10px 30px rgba(23,50,77,.05);" onmouseenter="this.style.boxShadow='0 16px 38px rgba(23,50,77,.14)'" onmouseleave="this.style.boxShadow='0 10px 30px rgba(23,50,77,.05)'">
  <div class="w-[50px] h-[50px] bg-teal-tint rounded-[12px] flex items-center justify-center mb-4">
    <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="#5AA7A7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      {% if card.slug == "recurring-cleaning" %}
      <rect x="3" y="4" width="16" height="16" rx="2"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="14" y1="2" x2="14" y2="6"/><line x1="3" y1="10" x2="19" y2="10"/><circle cx="14" cy="15" r="1" fill="#5AA7A7"/>
      {% elif card.slug == "deep-cleaning" %}
      <circle cx="11" cy="11" r="8"/><line x1="11" y1="7" x2="11" y2="11"/><line x1="11" y1="11" x2="14" y2="13"/>
      {% elif card.slug == "move-in-move-out-cleaning" %}
      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><rect x="9" y="14" width="4" height="4" rx="0.5"/>
      {% elif card.slug == "condo-cleaning" %}
      <rect x="4" y="2" width="14" height="20" rx="1"/><line x1="8" y1="6" x2="8" y2="6"/><line x1="12" y1="6" x2="12" y2="6"/><line x1="8" y1="10" x2="8" y2="10"/><line x1="12" y1="10" x2="12" y2="10"/><line x1="8" y1="14" x2="8" y2="14"/><line x1="12" y1="14" x2="12" y2="14"/>
      {% else %}
      <circle cx="11" cy="11" r="8"/><polyline points="11 7 11 11 14 13"/>
      {% endif %}
    </svg>
  </div>
  <h3 class="font-display font-bold text-navy text-[18px] mb-2 leading-snug">{{ card.cardTitle }}</h3>
  <p class="text-[#4A5568] text-[14.5px] leading-relaxed mb-4">{{ card.cardDesc }}</p>
  <span class="text-teal font-semibold text-[14px] group-hover:underline">Learn more &rarr;</span>
</a>
