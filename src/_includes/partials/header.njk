<header class="sticky top-0 z-50 bg-navy">
  <div class="max-w-[1180px] mx-auto px-8 flex items-center justify-between h-16">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <span class="w-[34px] h-[34px] bg-teal rounded-lg flex items-center justify-center font-display font-extrabold text-navy text-lg leading-none select-none">P</span>
      <span class="font-display font-bold text-white text-[17px] leading-none">Port Credit Cleaners</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-7" aria-label="Main navigation">
      {% for item in site.nav %}
      <a href="{{ item.href }}" class="text-[#CDD6E0] hover:text-white text-[14.5px] font-medium transition-colors duration-150 {% if page.url == item.href %}text-white{% endif %}">{{ item.label }}</a>
      {% endfor %}
    </nav>

    <!-- Desktop right -->
    <div class="hidden md:flex items-center gap-5 shrink-0">
      <a href="{{ site.phoneTel }}" class="text-white font-semibold text-[14.5px] hover:text-teal transition-colors duration-150">{{ site.phone }}</a>
      <a href="/#quote" class="bg-teal hover:bg-teal-hover text-white font-semibold text-[14px] px-4 py-2 rounded-[10px] transition-colors duration-150 whitespace-nowrap">Get a Free Quote</a>
    </div>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="md:hidden text-white p-2 -mr-2" aria-label="Open menu" aria-expanded="false">
      <svg id="menu-icon-open" width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="19" y2="6"/><line x1="3" y1="11" x2="19" y2="11"/><line x1="3" y1="16" x2="19" y2="16"/>
      </svg>
      <svg id="menu-icon-close" class="hidden" width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="4" y1="4" x2="18" y2="18"/><line x1="18" y1="4" x2="4" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-navy border-t border-white/10">
    <nav class="max-w-[1180px] mx-auto px-8 py-4 flex flex-col gap-1">
      {% for item in site.nav %}
      <a href="{{ item.href }}" class="text-[#CDD6E0] hover:text-white text-[15px] font-medium py-2.5 border-b border-white/5 last:border-0 transition-colors duration-150">{{ item.label }}</a>
      {% endfor %}
      <div class="pt-3 flex flex-col gap-2.5">
        <a href="{{ site.phoneTel }}" class="text-white font-semibold text-[15px]">{{ site.phone }}</a>
        <a href="/#quote" class="bg-teal hover:bg-teal-hover text-white font-semibold text-[14px] px-4 py-2.5 rounded-[10px] text-center transition-colors duration-150">Get a Free Quote</a>
      </div>
    </nav>
  </div>
</header>
