<footer class="bg-navy-deep text-white">
  <div class="max-w-[1180px] mx-auto px-8 pt-14 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <span class="w-[34px] h-[34px] bg-teal rounded-lg flex items-center justify-center font-display font-extrabold text-navy text-lg leading-none select-none">P</span>
          <span class="font-display font-bold text-white text-[16px] leading-none">Port Credit Cleaners</span>
        </a>
        <p class="text-[#8DA0B4] text-[14px] leading-relaxed">Reliable, locally-owned house and condo cleaning across Port Credit and South Mississauga.</p>
        <div class="flex gap-4 mt-5">
          <a href="{{ site.social.facebook }}" aria-label="Facebook" class="text-[#8DA0B4] hover:text-white transition-colors duration-150">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="{{ site.social.instagram }}" aria-label="Instagram" class="text-[#8DA0B4] hover:text-white transition-colors duration-150">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="{{ site.social.google }}" aria-label="Google Business" class="text-[#8DA0B4] hover:text-white transition-colors duration-150">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 11h8.533c.044.385.067.78.067 1.184C20.6 17.48 17.04 21 12 21a9 9 0 1 1 0-18c2.477 0 4.707.985 6.33 2.58L16.1 7.8A6 6 0 1 0 12 18c2.91 0 5.044-1.738 5.716-4H12v-3z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold text-[13px] uppercase tracking-[0.1em] mb-4">Services</h3>
        <ul class="space-y-2.5">
          {% for s in services %}
          <li><a href="/services/{{ s.slug }}/" class="text-[#8DA0B4] hover:text-white text-[14px] transition-colors duration-150">{{ s.cardTitle }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white font-semibold text-[13px] uppercase tracking-[0.1em] mb-4">Company</h3>
        <ul class="space-y-2.5">
          <li><a href="/" class="text-[#8DA0B4] hover:text-white text-[14px] transition-colors duration-150">Home</a></li>
          <li><a href="/about/" class="text-[#8DA0B4] hover:text-white text-[14px] transition-colors duration-150">About</a></li>
          <li><a href="/#testimonials" class="text-[#8DA0B4] hover:text-white text-[14px] transition-colors duration-150">Testimonials</a></li>
          <li><a href="/#service-area" class="text-[#8DA0B4] hover:text-white text-[14px] transition-colors duration-150">Service Area</a></li>
          <li><a href="/contact/" class="text-[#8DA0B4] hover:text-white text-[14px] transition-colors duration-150">Contact</a></li>
        </ul>
      </div>

      <!-- Get in touch -->
      <div>
        <h3 class="text-white font-semibold text-[13px] uppercase tracking-[0.1em] mb-4">Get in touch</h3>
        <ul class="space-y-2.5">
          <li><a href="{{ site.phoneTel }}" class="text-[#8DA0B4] hover:text-white text-[14px] transition-colors duration-150">{{ site.phone }}</a></li>
          <li><a href="mailto:{{ site.email }}" class="text-[#8DA0B4] hover:text-white text-[14px] transition-colors duration-150">{{ site.email }}</a></li>
          <li><a href="{{ site.social.google }}" class="text-[#8DA0B4] hover:text-white text-[14px] transition-colors duration-150">Google Business Profile</a></li>
          <li><span class="text-[#8DA0B4] text-[14px]">{{ site.location }}</span></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row md:items-center md:justify-between gap-2">
      <p class="text-[#8DA0B4] text-[13px]">&copy; {{ "" | currentYear }} Port Credit Cleaners. All rights reserved.</p>
      <p class="text-[#5A7290] text-[12px]">House Cleaning &middot; Condo Cleaning &middot; Deep Cleaning &mdash; Port Credit, ON</p>
    </div>
  </div>
</footer>
