<form id="contact-form" action="/api/lead" method="POST" data-form="contact" class="space-y-4" novalidate>
  <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true">
  <div>
    <label for="cf-name" class="block text-[13px] font-semibold text-[#3C4754] mb-1.5">Name <span class="text-red-500">*</span></label>
    <input type="text" id="cf-name" name="name" required placeholder="Your name" class="w-full bg-surface border border-[#E2E6EC] rounded-[10px] px-3.5 py-3 text-[15px] text-ink placeholder-[#9CA3AF] focus:outline-none focus:border-teal focus:bg-white" style="transition: border-color .15s, box-shadow .15s;" onfocus="this.style.boxShadow='0 0 0 3px rgba(90,167,167,.15)'" onblur="this.style.boxShadow='none'">
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="cf-phone" class="block text-[13px] font-semibold text-[#3C4754] mb-1.5">Phone</label>
      <input type="tel" id="cf-phone" name="phone" placeholder="(905) 000-0000" class="w-full bg-surface border border-[#E2E6EC] rounded-[10px] px-3.5 py-3 text-[15px] text-ink placeholder-[#9CA3AF] focus:outline-none focus:border-teal focus:bg-white" style="transition: border-color .15s, box-shadow .15s;" onfocus="this.style.boxShadow='0 0 0 3px rgba(90,167,167,.15)'" onblur="this.style.boxShadow='none'">
    </div>
    <div>
      <label for="cf-email" class="block text-[13px] font-semibold text-[#3C4754] mb-1.5">Email</label>
      <input type="email" id="cf-email" name="email" placeholder="you@email.com" class="w-full bg-surface border border-[#E2E6EC] rounded-[10px] px-3.5 py-3 text-[15px] text-ink placeholder-[#9CA3AF] focus:outline-none focus:border-teal focus:bg-white" style="transition: border-color .15s, box-shadow .15s;" onfocus="this.style.boxShadow='0 0 0 3px rgba(90,167,167,.15)'" onblur="this.style.boxShadow='none'">
    </div>
  </div>
  <div>
    <label for="cf-message" class="block text-[13px] font-semibold text-[#3C4754] mb-1.5">How can we help?</label>
    <textarea id="cf-message" name="message" rows="4" placeholder="Tell us about your home and what you're looking for…" class="w-full bg-surface border border-[#E2E6EC] rounded-[10px] px-3.5 py-3 text-[15px] text-ink placeholder-[#9CA3AF] resize-none focus:outline-none focus:border-teal focus:bg-white" style="transition: border-color .15s, box-shadow .15s;" onfocus="this.style.boxShadow='0 0 0 3px rgba(90,167,167,.15)'" onblur="this.style.boxShadow='none'"></textarea>
  </div>
  <button type="submit" class="w-full bg-teal hover:bg-teal-hover text-white font-semibold text-[15px] py-3.5 rounded-[10px] transition-colors duration-150">Send Message</button>
  <p class="text-center text-[13px] text-[#6B7280]">Prefer to talk? Call or text <a href="{{ site.phoneTel }}" class="text-teal hover:underline">{{ site.phone }}</a></p>
  <div class="form-error hidden text-red-600 text-[14px] font-medium text-center" role="alert"></div>
</form>
