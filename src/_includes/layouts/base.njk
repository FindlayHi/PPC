<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title if title else site.name }}</title>
    <meta name="description" content="{{ description if description else 'Professional, locally-owned house and condo cleaning in Port Credit, Mississauga.' }}" />
    <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:site_name" content="{{ site.name }}" />
    <meta property="og:title" content="{{ title if title else site.name }}" />
    <meta property="og:description" content="{{ description if description else 'Professional, locally-owned house and condo cleaning in Port Credit, Mississauga.' }}" />
    <meta property="og:url" content="{{ site.url }}{{ page.url }}" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="/css/styles.css" />

    {% if jsonld %}
    <script type="application/ld+json">{{ jsonld | safe }}</script>
    {% endif %}
  </head>
  <body class="bg-white font-sans text-ink antialiased">
    {% include "partials/header.njk" %}
    {{ content | safe }}
    {% include "partials/footer.njk" %}
    {% include "partials/mobile-cta.njk" %}
    <script>
      window.PCC_CONFIG = {
        supabaseUrl: {{ site.supabaseUrl | dump | safe }},
        supabaseAnonKey: {{ site.supabaseAnonKey | dump | safe }}
      };
    </script>
    <script src="/js/main.js" defer></script>
  </body>
</html>
