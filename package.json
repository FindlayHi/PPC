{
  "name": "pcc-site",
  "version": "1.0.0",
  "description": "Port Credit Cleaners — Eleventy static site",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n eleventy,tailwind \"eleventy --serve\" \"tailwindcss -i src/styles/tailwind.css -o _site/css/styles.css --watch\"",
    "build": "tailwindcss -i src/styles/tailwind.css -o _site/css/styles.css --minify && eleventy",
    "preview": "eleventy --serve"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@tailwindcss/cli": "^4.1.8",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.1.8"
  }
}
